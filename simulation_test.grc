options:
  parameters:
    author: ''
    catch_exceptions: 'True'
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: ''
    copyright: ''
    description: Smart GFSK Loopback with Custom Media Source/Sink
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: no_gui
    hier_block_src_path: '.: '
    id: simulation_test
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: Smart GFSK Test
    window_size: (1000,1000)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: samp_rate
  id: variable
  parameters:
    comment: ''
    value: '1000000'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [184, 12]
    rotation: 0
    state: enabled
- name: channels_channel_model_0
  id: channels_channel_model
  parameters:
    affinity: ''
    alias: ''
    block_tags: 'False'
    comment: ''
    epsilon: '1.0'
    freq_offset: '0.0'
    maxoutbuf: '0'
    minoutbuf: '0'
    noise_voltage: '0.1'
    seed: '0'
    taps: '1.0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [464, 156.0]
    rotation: 0
    state: enabled
- name: custom_gfsk_custom_file_sink_0
  id: custom_gfsk_custom_file_sink
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    output_file: /Users/harishankar/Documents/gitClone/SDR_USPR_B210/images/shadab_output.jpg
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [880, 180.0]
    rotation: 0
    state: enabled
- name: custom_gfsk_custom_file_source_0
  id: custom_gfsk_custom_file_source
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    filepath: /Users/harishankar/Documents/gitClone/SDR_USPR_B210/images/shadab.jpeg
    image_quality: '30'
    maxoutbuf: '0'
    minoutbuf: '0'
    video_bitrate: '200'
    video_fps: '24'
    video_resolution: '480'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [24, 180.0]
    rotation: 0
    state: enabled
- name: custom_gfsk_rx_0
  id: custom_gfsk_rx
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    enable_fec: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    sample_rate: samp_rate
    samples_per_symbol: '2'
    sync_threshold: '4'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [648, 160.0]
    rotation: 0
    state: enabled
- name: custom_gfsk_tx_0
  id: custom_gfsk_tx
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    enable_fec: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    samples_per_symbol: '2'
    tx_amplitude: '0.7'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [224, 180.0]
    rotation: 0
    state: enabled

connections:
- [channels_channel_model_0, '0', custom_gfsk_rx_0, '0']
- [custom_gfsk_custom_file_source_0, '0', custom_gfsk_tx_0, '0']
- [custom_gfsk_rx_0, '0', custom_gfsk_custom_file_sink_0, '0']
- [custom_gfsk_tx_0, '0', channels_channel_model_0, '0']

metadata:
  file_format: 1
  grc_version: 3.10.12.0
